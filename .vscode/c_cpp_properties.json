{
  "version": 4,
  "enableConfigurationSquiggles": true,
  "configurations": [
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/gcc",
      "intelliSenseMode": "linux-gcc-x64",
      "cStandard": "c17",
      "defines": [],
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/libft",
        "${workspaceFolder}/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/libft"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
