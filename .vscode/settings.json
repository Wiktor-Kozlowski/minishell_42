{
  "makefile.configureOnOpen": false,

  "[c]": {
    "editor.defaultFormatter": "keyhr.42-c-format",
    "editor.formatOnSave": true,
    "editor.insertSpaces": false,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "editor.rulers": [80]
  },

  "files.associations": {
    "*.h": "c"
  },

  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  "files.exclude": {
    "**/.vscode-server": true,
    "**/.vscode-server/**": true,
    "**/.git": true,
    "**/*.o": true,
    "**/*.a": true,
    "**/build": true
  },

  "search.exclude": {
    "**/.vscode-server": true,
    "**/.vscode-server/**": true,
    "**/.git": true,
    "**/*.o": true,
    "**/*.a": true,
    "**/build": true
  },

  "files.watcherExclude": {
    "**/.vscode-server/**": true
  }
}
